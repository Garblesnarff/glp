VITE_APP_ENV=development
VITE_APP_URL=http://127.0.0.1:5533
VITE_NOTIFICATION_EMAIL_AVAILABLE=false
VITE_NOTIFICATION_SMS_AVAILABLE=false

# WorkOS
VITE_WORKOS_CLIENT_ID=your-workos-client-id
VITE_WORKOS_REDIRECT_URI=http://127.0.0.1:5533/auth/callback
VITE_WORKOS_API_HOSTNAME=auth.example.com
VITE_WORKOS_COOKIE_PASSWORD=replace-me-in-server-env

# Supabase
VITE_SUPABASE_URL=https://your-supabase.example.com
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_SUPABASE_PROJECT_REF=your-project-ref

# Bun notification worker
SUPABASE_URL=https://your-supabase.example.com
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Optional worker-side transport providers
RESEND_API_KEY=your-resend-api-key
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_FROM_NUMBER=your-twilio-from-number
