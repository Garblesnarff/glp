{
  "name": "glp-meal-planner",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "bun@1.2.8",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "test": "bun test",
