VITE_APP_ENV=production
VITE_APP_URL=https://glp.infiniterealms.tech

# Keep these false until external delivery is actually live.
VITE_NOTIFICATION_EMAIL_AVAILABLE=false
VITE_NOTIFICATION_SMS_AVAILABLE=false

# WorkOS
VITE_WORKOS_CLIENT_ID=your-workos-client-id
VITE_WORKOS_REDIRECT_URI=https://glp.infiniterealms.tech/auth/callback
VITE_WORKOS_API_HOSTNAME=your-workos-auth-domain

# Self-hosted Supabase public values
VITE_SUPABASE_URL=https://glp.infiniterealms.tech
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_SUPABASE_PROJECT_REF=glp-self-hosted

# Bun notification worker
SUPABASE_URL=https://glp.infiniterealms.tech
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Optional worker-side transport providers
RESEND_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
